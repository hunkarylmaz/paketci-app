RewriteEngine On

# If the request is for a file or directory that exists, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect / to dealer login
RewriteRule ^$ /dealer/login.html [L,R=301]

# Handle dealer routes
RewriteRule ^dealer/login$ /dealer/login.html [L]
RewriteRule ^dealer/dashboard$ /dealer/dashboard.html [L]
RewriteRule ^dealer$ /dealer/login.html [L,R=301]

# Handle all other routes by serving index.html
RewriteRule ^ index.html [L]