RewriteEngine On

# If the request is for a file or directory that exists, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle courier routes
RewriteRule ^courier/login$ /courier/login.html [L]
RewriteRule ^courier/dashboard$ /courier/dashboard.html [L]
RewriteRule ^courier$ /courier/login.html [L,R=301]

# Redirect root to courier login
RewriteRule ^$ /courier/login.html [L]

# Handle all other routes
RewriteRule ^ index.html [L]