# ===========================================
# 🚀 PAKETÇİ SİSTEMİ - paketciniz.com ENVIRONMENT
# ===========================================

# ------------------------------
# 🌐 DOMAIN CONFIGURATION
# ------------------------------
DOMAIN=paketciniz.com
ADMIN_DOMAIN=paketci.paketciniz.com
PARTNER_DOMAIN=partner.paketciniz.com
RESTAURANT_DOMAIN=isletme.paketciniz.com
API_DOMAIN=api.paketciniz.com

# ------------------------------
# 🗄️ DATABASE
# ------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=KuryePass123!
DB_NAME=kurye_db

# ------------------------------
# 🔴 REDIS
# ------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------
# 🔐 JWT & SECURITY
# ------------------------------
JWT_SECRET=change-this-to-a-super-secret-random-string-min-64-characters
ENCRYPTION_KEY=another-super-secret-key-for-api-key-encryption-32chars

# ------------------------------
# 🌐 API URLS (Production)
# ------------------------------
API_URL=https://api.paketciniz.com
ADMIN_URL=https://paketci.paketciniz.com
PARTNER_URL=https://partner.paketciniz.com
RESTAURANT_URL=https://isletme.paketciniz.com

# ------------------------------
# 📱 PLATFORM API KEYS
# ------------------------------
# These are set by restaurants in their panel, not here
# Each restaurant adds their own API keys through the UI

# ------------------------------
# 🔥 FIREBASE (Push Notifications)
# ------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=
FIREBASE_SERVER_KEY=

# ------------------------------
# 📞 TWILIO (SMS - Optional)
# ------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ------------------------------
# 💳 PAYMENT (Optional)
# ------------------------------
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ------------------------------
# 📧 SMTP (Email - Optional)
# ------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@paketciniz.com

# ------------------------------
# 🐳 DOCKER
# ------------------------------
COMPOSE_PROJECT_NAME=paketci
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ------------------------------
# 🔧 DEVELOPMENT (Local)
# ------------------------------
# API_URL=http://localhost:4000
# ADMIN_URL=http://localhost:3000
